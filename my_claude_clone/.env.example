# Claude Clone — .env.example
# Скопируй в .env и заполни своими ключами

# Обязательно
SECRET_KEY=change-me-please

# AI Провайдер (anthropic / groq / openrouter / mock)
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Антропик (Claude 3.5)
ANTHROPIC_API_KEY=

# Groq (бесплатно на console.groq.com)
GROQ_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Google Search (необязательно)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# GitHub (для Local MCP Server — github.com/settings/tokens)
GITHUB_TOKEN=

# Стриминг и MCP
ENABLE_STREAMING=true
ENABLE_MCP=true
