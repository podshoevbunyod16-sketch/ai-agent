# ============================================================
# AI Chat Agent — Environment Variables
# ============================================================
# Copy to .env (backend) and .env.local (frontend), fill in real values.
# DO NOT commit .env files with real secrets to git!

# -----------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------
# Groq API: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily Search API: https://app.tavily.com/home (free tier available)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# Firebase — Backend (Service Account)
# -----------------------------------------------------------
# Download serviceAccountKey.json from Firebase Console:
# Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as a single-line string:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------
# Firebase — Frontend Config (also set in .env.local for Vite)
# -----------------------------------------------------------
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# SQLite locally (default), PostgreSQL on Render via DATABASE_URL
DATABASE_URL=sqlite:///./ai_chat.db
# For PostgreSQL on Render:
# DATABASE_URL=postgresql://user:pass@host.render.com:5432/dbname

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
PORT=8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------
# App Defaults
# -----------------------------------------------------------
DEFAULT_LLM_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile
